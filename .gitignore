docs/_build/

# PyBuilder
.pybuilder/
target/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# pyenv
#   For a library or app, you might want to share your .python-version.  
#   It makes the project more portable.
# .python-version

# pipenv
#   According to pypa/pipenv#1190, it is recommended to not commit Pipfile.lock
#   when you are developing a library. If this is an app, you should commit it.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock is typically committed for applications,
#   but not for libraries.
#poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock is typically committed for applications
#   pdm.lock
#   Visual Studio Code users template
.pdm-python
.pdm-build/

# PEP 582; used by e.g. github.com/lincolnloop/layman and pdm
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath parsed files
*.sage.py

# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Spyder project settings
.spyderproject
.spyproject

# Rope project settings
.ropeproject

# mkdocs documentation
/site

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

